#!/usr/bin/env bash
# revive — deterministic context brief for Claude Code
# https://github.com/justi/context-revive
set -euo pipefail

VERSION="0.1.17"
STATIC_FILE=".revive/static.md"
COMMANDS_FILE=".revive/commands.md"
BRIEF_CHAR_BUDGET=2200

LOG_DIR="${HOME}/.context-revive"
LOG_FILE="${LOG_DIR}/hook.log"

COUNTER_FILE=".claude/revive-counter"
REFRESH_EVERY="${REVIVE_REFRESH_EVERY:-5}"
REFRESH_TIME_GAP="${REVIVE_REFRESH_TIME_GAP:-600}"  # seconds

usage() {
  cat <<'EOF'
Usage: revive <command> [options]

Commands:
  init              Generate .revive/static.md (PURPOSE, DIFFERENTIATORS,
                    INVARIANTS, GOTCHAS). Use `init --force` to regenerate
                    PURPOSE from the chain while preserving user-edited
                    DIFFERENTIATORS, INVARIANTS, and GOTCHAS.
  suggest           Print an LLM-ready prompt that, when pasted into any
                    coding agent, generates PURPOSE + DIFFERENTIATORS +
                    INVARIANTS + GOTCHAS for this project. Tailored to the
                    actual files in the repo.
  audit             Print an LLM-ready prompt for a second-pass gap audit
                    of .revive/static.md. Run in a FRESH agent session
                    after `suggest` — a clean context window catches
                    non-inferable facts the generation pass missed.
  show              Print the brief that would be injected (force-emit)
  refresh           Hook entry point — cadence-gated, silent on failure
  install-hook      Wire UserPromptSubmit into .claude/settings.json
                    (use --global for ~/.claude/settings.json)
  version           Print version
EOF
}

cmd_version() { echo "revive $VERSION"; }

# --- logging ----------------------------------------------------------------

log() {
  mkdir -p "$LOG_DIR" 2>/dev/null || return 0
  printf '[%s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$*" \
    >> "$LOG_FILE" 2>/dev/null || true
}

# --- DYNAMIC section builders -----------------------------------------------

# Extract the first paragraph of a commit's body, joined to a single line,
# truncated to 100 chars with a `…` suffix. Returns non-zero when no usable
# body exists — caller should skip the body line entirely.
#
# Rationale: commit subjects carry the "what", bodies carry the "why" /
# root-cause / approach — the essence users reach for when debugging later.
# For squash-merge workflows, commit body === PR body, so this also
# surfaces PR descriptions without needing `gh` at runtime.
commit_body_excerpt() {
  local sha="$1"
  local body
  body=$(git log -1 --pretty=%b "$sha" 2>/dev/null) || return 1
  [[ -n "$body" ]] || return 1
  # Skip leading template boilerplate before picking the first real
  # paragraph:
  #  - markdown atx headings (`## Summary` etc.)
  #  - single-line HTML comments (`<!-- ... -->`), including multiple per
  #    line and comment bodies that contain `>` characters (`<!-- x > 0 -->`)
  #  - multi-line HTML comment blocks (`<!--\n  ...\n-->`)
  #
  # Crucially: lines that become empty ONLY because a comment was stripped
  # do NOT terminate the first paragraph. Bodies like
  # `Line one\n<!-- note -->\nLine two` must produce "Line one Line two",
  # not "Line one".
  local para
  para=$(awk '
    BEGIN { p = ""; in_para = 0; in_comment = 0 }

    # Capture whether the INPUT line was blank, before any stripping.
    # Only originally-blank lines terminate a paragraph.
    { orig_blank = ($0 ~ /^[[:space:]]*$/) }

    # Finish a multi-line HTML comment block that opened on an earlier line.
    in_comment {
      idx = index($0, "-->")
      if (idx == 0) next                      # still fully inside
      $0 = substr($0, idx + 3)                # keep remainder after "-->"
      in_comment = 0
    }

    # Strip inline <!-- ... --> comments via index-based scan so the comment
    # body may safely contain `>` characters (which `[^>]*` would break on).
    # Handles multiple comments per line and unclosed openers.
    {
      while ((s = index($0, "<!--")) > 0) {
        rest = substr($0, s + 4)
        e = index(rest, "-->")
        if (e == 0) {
          # unclosed: drop from <!-- onward; resume on next line
          $0 = substr($0, 1, s - 1)
          in_comment = 1
          break
        }
        $0 = substr($0, 1, s - 1) substr($0, s + 4 + e + 2)
      }
    }

    # Markdown atx headings — whole line is template, skip.
    /^#+[[:space:]]/ { next }

    # Normalize whitespace before deciding blank vs content.
    { sub(/^[[:space:]]+/, ""); sub(/[[:space:]]+$/, "") }

    # Blank:
    #  - if the ORIGINAL line was blank, this is a paragraph boundary
    #  - if the line emptied only because we stripped a comment, skip
    #    it transparently so the paragraph continues on the next line
    $0 == "" {
      if (orig_blank) {
        if (in_para) exit
        next
      }
      next
    }

    # Real content
    {
      p = (p == "" ? $0 : p " " $0)
      in_para = 1
    }

    END { print p }
  ' <<<"$body")
  para=$(sed 's/  */ /g; s/^ //; s/ $//' <<<"$para")
  [[ -n "$para" ]] || return 1
  local max=100
  if (( ${#para} > max )); then
    para="${para:0:$max}…"
  fi
  printf '%s\n' "$para"
}

dyn_state() {
  local branch
  if branch=$(git symbolic-ref --short HEAD 2>/dev/null); then
    echo "STATE: branch=${branch}"
    local sha subj body
    while IFS= read -r sha; do
      [[ -z "$sha" ]] && continue
      subj=$(git log -1 --pretty=%s "$sha" 2>/dev/null || true)
      printf '  %s %s\n' "${sha:0:7}" "$subj"
      if body=$(commit_body_excerpt "$sha") && [[ -n "$body" ]]; then
        printf '      ↪ %s\n' "$body"
      fi
    done < <(git log --pretty=%H -3 2>/dev/null || true)
  elif git rev-parse --git-dir >/dev/null 2>&1; then
    echo "STATE: (git repo, no commits yet)"
  else
    echo "STATE: (not a git repo)"
  fi
}

dyn_todo() {
  # Omit the section entirely when no source file is found — consistent
  # with COMMANDS section behavior and the "show nothing > show placeholder
  # noise" principle. Injecting "(no plan.md/TODO.md found)" into every
  # prompt is ~32 chars of zero-signal content.
  #
  # Search root first, then docs/ (common convention for mature projects).
  local f
  for f in plan.md PLAN.md TODO.md todo.md TODO ROADMAP.md \
           docs/plan.md docs/PLAN.md docs/TODO.md docs/todo.md docs/ROADMAP.md; do
    if [[ -f "$f" ]]; then
      echo "TODO: (from $f)"
      grep -vE '^\s*(#|$)' "$f" | head -3 | sed 's/^/  /'
      return
    fi
  done
}

# Extract up to top-5 well-known command labels (test/lint/build/dev/run/…).
# Sources, in priority order (first hit per label wins):
#   1. user override `.revive/commands.md` — dumped verbatim (max 5 lines)
#   2. package.json `scripts.<label>` for known labels
#   3. Makefile targets matching known labels
#   4. Rails-style bin/* (bin/dev, bin/rspec, bin/rubocop, bin/setup)
# Rationale (2026 research): "exact commands" are the canonical class of
# non-inferable facts agents need. Architecture overviews are not (they
# hurt performance); commands are.
# Append Rails-style bin/* commands to $1 file. Increments $found (eval'd).
_commands_rails() {
  local tmp="$1"
  local n=0
  [[ -x bin/dev ]]     && { echo "  run: bin/dev"       >> "$tmp"; n=$((n+1)); }
  [[ -x bin/rspec ]]   && { echo "  test: bin/rspec"    >> "$tmp"; n=$((n+1)); }
  [[ -x bin/rubocop ]] && { echo "  lint: bin/rubocop"  >> "$tmp"; n=$((n+1)); }
  [[ -x bin/setup ]]   && { echo "  setup: bin/setup"   >> "$tmp"; n=$((n+1)); }
  echo "$n"
}

_commands_npm() {
  local tmp="$1"
  local n=0 label script
  command -v jq >/dev/null 2>&1 || { echo 0; return; }
  for label in test lint build dev start typecheck format; do
    script=$(jq -r --arg k "$label" '(.scripts // {})[$k] // empty' package.json 2>/dev/null || true)
    if [[ -n "$script" ]]; then
      printf '  %s: %s\n' "$label" "$script" >> "$tmp"
      n=$((n+1))
      (( n >= 5 )) && break
    fi
  done
  echo "$n"
}

_commands_makefile() {
  local tmp="$1"
  local n=0 label
  for label in test lint build dev run install; do
    if grep -qE "^${label}:" Makefile 2>/dev/null; then
      printf '  %s: make %s\n' "$label" "$label" >> "$tmp"
      n=$((n+1))
      (( n >= 5 )) && break
    fi
  done
  echo "$n"
}

dyn_commands() {
  # "show nothing > show placeholder noise" per 2026 context-engineering
  # research. Section header is emitted only when body is non-empty.
  if [[ -f "$COMMANDS_FILE" ]]; then
    local body
    body=$(head -5 "$COMMANDS_FILE" | sed 's/^/  /')
    [[ -n "$body" ]] && { echo "COMMANDS:"; printf '%s\n' "$body"; }
    return
  fi

  local tmp found=0
  tmp=$(mktemp)

  # Primary-language detection: prefer conventions of whichever manifest
  # dominates the project. Rails apps often have a package.json for the
  # frontend toolchain, but their canonical commands are Ruby bin/* scripts.
  local ruby_primary=0 node_primary=0
  { [[ -f Gemfile ]] || ls -- *.gemspec >/dev/null 2>&1; } && ruby_primary=1
  [[ -f package.json ]] && node_primary=1

  if (( ruby_primary )); then
    found=$((found + $(_commands_rails "$tmp")))
  fi
  if (( found == 0 )) && (( node_primary )); then
    found=$((found + $(_commands_npm "$tmp")))
  fi
  if (( found == 0 )) && [[ -f Makefile ]]; then
    found=$((found + $(_commands_makefile "$tmp")))
  fi
  # fallback: try the other manifest if primary yielded nothing
  if (( found == 0 )) && (( node_primary )); then
    found=$((found + $(_commands_npm "$tmp")))
  fi
  if (( found == 0 )) && (( ruby_primary )); then
    found=$((found + $(_commands_rails "$tmp")))
  fi

  if (( found > 0 )); then
    echo "COMMANDS:"
    cat "$tmp"
  fi
  rm -f "$tmp"
}

dyn_hot_files() {
  echo "HOT_FILES: (last 20 commits, last change shown)"
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "  (not a git repo)"
    return
  fi
  local total
  total=$(git rev-list --count HEAD 2>/dev/null || echo 0)
  if (( total == 0 )); then
    echo "  (no history)"
    return
  fi

  # `|| true` is load-bearing: under `set -euo pipefail`, a grep that filters
  # every line returns 1 and would abort the whole brief (e.g. a run of
  # lockfile-only commits).
  local files
  files=$(git log --name-only --pretty=format: -20 2>/dev/null \
    | grep -v '^$' \
    | grep -vE '(^|/)(package-lock\.json|pnpm-lock\.yaml)$|\.lock$|\.min\.(js|css)$|^(dist|build|node_modules|vendor)/' \
    | sort | uniq -c | sort -rn | head -5 || true)

  if [[ -z "$files" ]]; then
    echo "  (no files touched)"
    return
  fi

  while IFS= read -r line; do
    local count path msg
    count=$(echo "$line" | awk '{print $1}')
    path=$(echo "$line" | awk '{$1=""; sub(/^ /,""); print}')
    printf '  %d× %s\n' "$count" "$path"
    msg=$(git log -1 --pretty=%s -- "$path" 2>/dev/null)
    [[ -n "$msg" ]] && printf '      └ "%s"\n' "$msg"
  done <<<"$files"
}

# --- STATIC section ---------------------------------------------------------

# Emit STATIC section, skipping placeholder-only INVARIANTS/GOTCHAS blocks.
# Rationale: injecting "(edit this file)" into every prompt is pure noise —
# research prefers empty sections to placeholder ones.
static_section() {
  if [[ ! -f "$STATIC_FILE" ]]; then
    cat <<EOF
PURPOSE: (run \`revive init\` to scaffold $STATIC_FILE)
EOF
    return
  fi
  awk '
    # state: section header line currently being considered
    # strategy: buffer each section, emit only if its body has non-placeholder content
    function flush() {
      if (NR_buf == 0) return
      has_real = 0
      for (i = 1; i <= NR_buf; i++) {
        line = buf[i]
        # the header itself always counts
        if (i == 1) continue
        # skip placeholder lines
        if (line ~ /^[[:space:]]*-?[[:space:]]*\(/ && line ~ /edit this file|none defined/) continue
        if (line ~ /^[[:space:]]*$/) continue
        has_real = 1; break
      }
      if (has_real || buf[1] ~ /^PURPOSE:/) {
        for (i = 1; i <= NR_buf; i++) print buf[i]
      } else {
        # collapse to one-line marker so placement stays stable
        # (strip bullet points entirely)
        print buf[1]
      }
      NR_buf = 0
    }
    /^(PURPOSE|DIFFERENTIATORS|INVARIANTS|GOTCHAS):/ { flush(); buf[++NR_buf] = $0; next }
    { buf[++NR_buf] = $0 }
    END { flush() }
  ' "$STATIC_FILE"
}

# --- brief assembler --------------------------------------------------------

build_brief() {
  local refresh_n="${1:-0}"
  printf '<revive refresh="%s">\n' "$refresh_n"
  echo "# STATIC"
  static_section
  echo
  echo "# DYNAMIC"
  dyn_state
  dyn_todo
  dyn_hot_files
  dyn_commands
  echo "</revive>"
}

# --- cadence ----------------------------------------------------------------

# counter file format: "N:LAST_EMIT_EPOCH"
read_counter() {
  if [[ -f "$COUNTER_FILE" ]]; then
    cat "$COUNTER_FILE" 2>/dev/null || echo "0:0"
  else
    echo "0:0"
  fi
}

write_counter() {
  mkdir -p "$(dirname "$COUNTER_FILE")" 2>/dev/null || return 0
  printf '%s:%s\n' "$1" "$2" > "$COUNTER_FILE" 2>/dev/null || true
}

# returns 0 (emit) or 1 (skip); prints "n" on stdout when emitting
cadence_gate() {
  local state n last now gap
  state=$(read_counter)
  n="${state%%:*}"
  last="${state##*:}"
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  [[ "$last" =~ ^[0-9]+$ ]] || last=0

  now=$(date +%s)
  n=$((n + 1))
  gap=$((now - last))

  local emit=0
  if (( n == 1 )); then emit=1
  elif (( n % REFRESH_EVERY == 0 )); then emit=1
  elif (( gap > REFRESH_TIME_GAP )); then emit=1
  fi

  if (( emit )); then
    write_counter "$n" "$now"
    echo "$n"
    return 0
  else
    write_counter "$n" "$last"
    return 1
  fi
}

# --- commands ---------------------------------------------------------------

cmd_show() {
  local brief
  brief=$(build_brief "${REVIVE_REFRESH_N:-0}")
  printf '%s\n' "$brief"
  local len=${#brief}
  printf '\n--- %d chars (budget: %d) ---\n' "$len" "$BRIEF_CHAR_BUDGET" >&2
}

# refresh is the hook hot path: NEVER fail the session, always exit 0
cmd_refresh() {
  mkdir -p "$LOG_DIR" 2>/dev/null || true
  : >> "$LOG_FILE" 2>/dev/null || true
  set +e
  local n
  n=$(cadence_gate 2>>"$LOG_FILE")
  local gate_rc=$?
  if (( gate_rc == 0 )); then
    build_brief "$n" 2>>"$LOG_FILE" || log "build_brief failed"
  fi
  return 0
}

# --- PURPOSE extraction chain --------------------------------------------
# Order (each step is optional, falls through to next):
#   1. `gh repo view --json description` (curated 1-liner, highest quality)
#   2. Manifest description fields (pyproject.toml, package.json, Cargo.toml, *.gemspec, composer.json)
#   3. CLAUDE.md "## What this project is" / "## About" first paragraph
#   4. README.md filtered prose (blockquote-aware, strips badges/rulers/bullet-links)
#   5. Placeholder
#
# Each extractor prints the description on stdout and returns 0, or returns
# non-zero (or prints nothing) to signal "try the next source".

purpose_from_gh() {
  command -v gh >/dev/null 2>&1 || return 1
  git rev-parse --git-dir >/dev/null 2>&1 || return 1
  local d
  d=$(gh repo view --json description --jq '.description // empty' 2>/dev/null) || return 1
  [[ -n "$d" && "$d" != "null" ]] || return 1
  printf '%s\n' "$d"
}

purpose_from_pyproject() {
  [[ -f pyproject.toml ]] || return 1
  awk '
    /^\[project\]/           { in_p=1; next }
    /^\[/ && !/^\[project\]/ { in_p=0 }
    in_p && /^[[:space:]]*description[[:space:]]*=/ {
      sub(/^[[:space:]]*description[[:space:]]*=[[:space:]]*/, "")
      gsub(/^["'"'"']|["'"'"'][[:space:]]*$/, "")
      print; exit
    }
  ' pyproject.toml
}

purpose_from_package_json() {
  [[ -f package.json ]] || return 1
  local d=""
  if command -v jq >/dev/null 2>&1; then
    d=$(jq -r '.description // empty' package.json 2>/dev/null || true)
  fi
  if [[ -z "$d" ]]; then
    d=$(grep -E '"description"[[:space:]]*:' package.json | head -1 \
        | sed -E 's/.*"description"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')
  fi
  [[ -n "$d" ]] && printf '%s\n' "$d"
}

purpose_from_cargo() {
  [[ -f Cargo.toml ]] || return 1
  awk '
    /^\[package\]/           { in_p=1; next }
    /^\[/ && !/^\[package\]/ { in_p=0 }
    in_p && /^[[:space:]]*description[[:space:]]*=/ {
      sub(/^[[:space:]]*description[[:space:]]*=[[:space:]]*/, "")
      gsub(/^["'"'"']|["'"'"'][[:space:]]*$/, "")
      print; exit
    }
  ' Cargo.toml
}

purpose_from_gemspec() {
  local gs line
  gs=$(find . -maxdepth 1 -name '*.gemspec' -print -quit 2>/dev/null)
  [[ -n "$gs" ]] || return 1
  line=$(grep -E '\.(summary|description)[[:space:]]*=' "$gs" | head -1) || return 1
  [[ -n "$line" ]] || return 1
  # Determine the outer delimiter and capture its payload so interior
  # apostrophes in double-quoted strings (and vice versa) survive intact.
  if [[ "$line" == *\"* ]]; then
    sed -E 's/^[^"]*"([^"]*)".*$/\1/' <<<"$line"
  elif [[ "$line" == *\'* ]]; then
    sed -E "s/^[^']*'([^']*)'.*\$/\1/" <<<"$line"
  fi
}

purpose_from_composer() {
  [[ -f composer.json ]] || return 1
  local d=""
  if command -v jq >/dev/null 2>&1; then
    d=$(jq -r '.description // empty' composer.json 2>/dev/null || true)
  fi
  if [[ -z "$d" ]]; then
    d=$(grep -E '"description"[[:space:]]*:' composer.json | head -1 \
        | sed -E 's/.*"description"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')
  fi
  [[ -n "$d" ]] && printf '%s\n' "$d"
}

purpose_from_claudemd() {
  [[ -f CLAUDE.md ]] || return 1
  # Accumulate the full first paragraph (hard-wrapped lines joined by a space)
  # rather than truncating at the first non-empty line. Stops at a blank line
  # or the next `##` heading.
  awk '
    /^##[[:space:]]+(What this project is|About)/ { cap=1; next }
    cap && /^##/ { exit }
    cap {
      if (NF == 0) { if (para != "") exit; next }
      para = (para == "" ? $0 : para " " $0)
    }
    END { if (para != "") print para }
  ' CLAUDE.md
}

# Filter badges, blockquote markers, rulers, bullet-link-only lines.
# Blockquotes that contain substantive text are accepted with `>` stripped.
purpose_from_readme() {
  [[ -f README.md ]] || return 1
  awk '
    # strip leading/trailing whitespace
    { gsub(/^[[:space:]]+|[[:space:]]+$/, "") }
    # skip empty, headers, code fences, html tags, images, badge shields
    /^$/ || /^#/ || /^```/ || /^</ || /^!\[/ { next }
    # skip horizontal rulers (ascii + unicode)
    /^[-=*_─═]{3,}$/ { next }
    # skip bullet-link-only markdown lines
    /^-[[:space:]]+\[.*\]\(.*\)/ { next }
    # skip leading badge-collections (link-only lines)
    /^\[!?\[/ { next }
    # strip blockquote marker but accept content
    /^>[[:space:]]*/ { sub(/^>[[:space:]]*/, "") }
    # skip lines that are still empty after stripping
    NF == 0 { next }
    { print; count++; if (count==2) exit }
  ' README.md | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

# Cap PURPOSE at the end of the first sentence OR 400 chars, whichever
# comes first. Source extractors (CLAUDE.md, README) may join multi-line
# paragraphs into very long strings; injecting 800-char PURPOSE wastes
# budget and buries signal. Single-sentence 1-liners are the target.
#
# A "sentence boundary" is `[.!?]` followed by whitespace or end-of-input.
# This avoids mis-cutting on embedded dots like `package.json`, `ADR 0001.`
# mid-phrase, or filenames. Heuristic is deliberately simple — common
# English abbreviations (Dr., Inc.) may still cause false cuts, but those
# are rare in curated repo descriptions.
cap_purpose() {
  local text="$1"
  local max=400
  local n=${#text}
  local i=0 c next
  while (( i < n )); do
    c="${text:$i:1}"
    if [[ "$c" == "." || "$c" == "!" || "$c" == "?" ]]; then
      next="${text:$((i+1)):1}"
      if [[ -z "$next" || "$next" == " " || "$next" == $'\t' ]]; then
        printf '%s\n' "${text:0:$((i+1))}"
        return
      fi
    fi
    i=$((i+1))
    (( i > max )) && break
  done
  if (( n <= max )); then
    printf '%s\n' "$text"
  else
    printf '%s\n' "${text:0:$max}"
  fi
}

compute_purpose() {
  local p
  if p=$(purpose_from_gh)           && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_pyproject)    && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_package_json) && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_cargo)        && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_gemspec)      && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_composer)     && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_claudemd)     && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  if p=$(purpose_from_readme)       && [[ -n "$p" ]]; then cap_purpose "$p"; return; fi
  echo "(describe this project in 1-3 sentences)"
}

cmd_init() {
  local force=0
  local arg
  for arg in "$@"; do
    case "$arg" in
      --force|-f) force=1 ;;
      *) echo "unknown option: $arg" >&2; exit 1 ;;
    esac
  done

  if [[ -e "$STATIC_FILE" ]] && (( force == 0 )); then
    echo "exists: $STATIC_FILE (use --force to regenerate PURPOSE)" >&2
    exit 1
  fi

  # Preserve user-edited DIFFERENTIATORS / INVARIANTS / GOTCHAS across a
  # --force regenerate; only PURPOSE is replaced. This is the common flow
  # after upgrading revive — the chain got smarter, user rules haven't
  # changed.
  local differentiators="  - (what sets this project apart; edit this file)"
  local invariants="  - (top-5 architectural rules; edit this file)"
  local gotchas="  - (landmines you keep stepping on; edit this file)"
  if (( force )) && [[ -f "$STATIC_FILE" ]]; then
    local preserved
    preserved=$(awk '
      /^DIFFERENTIATORS:/ { cap="diff"; next }
      /^INVARIANTS:/      { cap="inv"; next }
      /^GOTCHAS:/         { cap="got"; next }
      /^[A-Z][A-Z_]*:/    { cap="" }
      cap == "diff" { diff = diff $0 "\n" }
      cap == "inv"  { inv = inv $0 "\n" }
      cap == "got"  { got = got $0 "\n" }
      END {
        printf "DIFF_START\n%sDIFF_END\nINV_START\n%sINV_END\nGOT_START\n%sGOT_END\n",
               diff, inv, got
      }
    ' "$STATIC_FILE")
    local saved_diff saved_inv saved_got
    saved_diff=$(awk '/^DIFF_START$/{p=1;next} /^DIFF_END$/{p=0} p' <<<"$preserved" | sed '/^$/d')
    saved_inv=$(awk '/^INV_START$/{p=1;next} /^INV_END$/{p=0} p' <<<"$preserved" | sed '/^$/d')
    saved_got=$(awk '/^GOT_START$/{p=1;next} /^GOT_END$/{p=0} p' <<<"$preserved" | sed '/^$/d')
    [[ -n "$saved_diff" ]] && differentiators="$saved_diff"
    [[ -n "$saved_inv" ]]  && invariants="$saved_inv"
    [[ -n "$saved_got" ]]  && gotchas="$saved_got"
  fi

  mkdir -p "$(dirname "$STATIC_FILE")"
  local purpose
  purpose=$(compute_purpose)
  {
    printf 'PURPOSE: %s\n' "$purpose"
    echo "DIFFERENTIATORS:"
    printf '%s\n' "$differentiators"
    echo "INVARIANTS:"
    printf '%s\n' "$invariants"
    echo "GOTCHAS:"
    printf '%s\n' "$gotchas"
  } > "$STATIC_FILE"
  if (( force )); then
    echo "regenerated: $STATIC_FILE (DIFFERENTIATORS/INVARIANTS/GOTCHAS preserved)"
  else
    echo "created: $STATIC_FILE"
  fi
}

# Build a prompt that a coding agent (Claude Code / Cursor / Aider / any
# chat-style LLM with file-read access) can execute against the current
# project to fill PURPOSE, INVARIANTS, and GOTCHAS in .revive/static.md.
#
# Keeps the agent's job focused: inject non-inferable rules only (no
# architecture / dir-tree / inferable-from-code noise).
cmd_suggest() {
  local sources=()
  [[ -f CLAUDE.md ]]    && sources+=("CLAUDE.md")
  [[ -f AGENTS.md ]]    && sources+=("AGENTS.md")
  [[ -f README.md ]]    && sources+=("README.md (first 100 lines)")
  [[ -d adr ]]          && sources+=("adr/*.md")
  [[ -d docs/adr ]]     && sources+=("docs/adr/*.md")
  [[ -d docs ]]         && sources+=("docs/*.md")
  [[ -f CHANGELOG.md ]] && sources+=("CHANGELOG.md (recent entries)")
  sources+=("git log --oneline -30")

  local hot=""
  if git rev-parse --git-dir >/dev/null 2>&1; then
    hot=$(git log --name-only --pretty=format: -20 2>/dev/null \
      | grep -v '^$' \
      | grep -vE '(^|/)(package-lock\.json|pnpm-lock\.yaml)$|\.lock$|\.min\.(js|css)$|^(dist|build|node_modules|vendor)/' \
      | sort | uniq -c | sort -rn | head -5 \
      | awk '{$1=""; sub(/^ /,""); print}' || true)
  fi

  # Meta-comments go to stderr so `revive suggest | pbcopy` lands a clean
  # prompt in the clipboard, not our framing.
  cat >&2 <<'PROMPT_META'
# Paste this prompt into your current Claude Code / Cursor / Aider session.
# The agent will: (1) preview PURPOSE + DIFFERENTIATORS + INVARIANTS +
# GOTCHAS, (2) edit .revive/static.md in place.
#
# For a second-pass gap audit, run `revive audit | pbcopy` afterwards
# and paste into a FRESH session — clean context window catches things
# the generation pass missed.
#
# Pipe to clipboard: `revive suggest | pbcopy` (macOS).
# Requires: .revive/static.md must already exist (run `revive init` first).
PROMPT_META

  cat <<'PROMPT_HEADER'
Read the following artefacts in the current project, then fill any
placeholder sections of .revive/static.md. Treat existing human-
curated content as sacred: PURPOSE, DIFFERENTIATORS, INVARIANTS,
and GOTCHAS that already contain real content must be preserved
verbatim — do not rewrite substantive sections just because you can.

Regenerate ONLY sections that are still in their `revive init`
placeholder state. Recognise a placeholder by these markers:

  - PURPOSE: literal `(describe this project in 1-3 sentences)`,
    OR a marketing-style 1-liner that states WHAT the project does
    but doesn't spell out WHY it exists / what success looks like.
    A gh repo description or README tagline typically falls in this
    category — it's readable, but doesn't give an agent enough to
    understand the business value or operating priorities.
    Rule of thumb: if the current PURPOSE could fit on a single
    marketing banner and a reader couldn't answer "what does success
    for this project look like?" from it alone, treat as placeholder.
  - DIFFERENTIATORS: bullets containing `(what sets this project
    apart; edit this file)` or `(none defined)`.
  - INVARIANTS: bullets containing `(top-5 architectural rules;
    edit this file)` or `(none defined)`.
  - GOTCHAS: bullets containing `(landmines you keep stepping on;
    edit this file)` or `(none defined)`.

Anything else is user-curated — leave it alone.

Files to read (read `.revive/static.md` FIRST — you need its current
contents to decide which sections are placeholders):
  - .revive/static.md (the file you will edit; checks placeholder
    state per section)
PROMPT_HEADER

  local s
  for s in "${sources[@]}"; do
    printf '  - %s\n' "$s"
  done

  if [[ -n "$hot" ]]; then
    echo "  - Top HOT_FILES (recent activity concentration):"
    while IFS= read -r f; do
      printf '      %s\n' "$f"
    done <<<"$hot"
  fi

  cat <<'PROMPT_BODY'

Strict rules (violations are failures, not stylistic preferences):

  1. Include ONLY non-inferable facts. If an agent can read it from the
     code with a single grep/ls, do NOT include it. Target rules that
     hurt only when broken — not conventions that are visible.
  2. Each bullet <= 120 characters. Dense > complete.
  3. Do NOT generate: architecture overviews, directory trees, module
     listings, dependency graphs, "we use Framework X" facts, or
     anything auto-inferable. (2026 research shows auto-generated
     structure degrades agent success rate by 0.5–2%.)
  4. Don't paraphrase the README verbatim for non-PURPOSE sections.
  5. If you can't back a claim with a specific file / ADR / commit /
     incident, OMIT it. Placeholder > false confidence.

Deliverable 1 — PURPOSE (single line, ≤ 400 chars):
  A tight 2-3 sentence summary that answers ALL THREE of:
    1. WHAT the project is (product one-liner)
    2. WHY it exists — business goal or success criterion the project
       is optimizing for (e.g. "cut X hours from weekly ops",
       "unlock audience Y", "prevent incident class Z", "reclaim
       DORMANT side projects")
    3. Its essential philosophy or hard constraint (what makes it
       different, the one thing every design decision must respect)

  All three must be present. A gh-style 1-liner that covers only (1)
  is NOT enough — it's a marketing tagline, not operating context.

  Bad examples:
    - "A Flutter app."                    (only 1, useless)
    - "Never forget a side project."      (only 1, marketing tagline)
    - 800-char pasted README intro        (too long, buries signal)

  Good examples (generic):
    - "A CLI that turns Markdown invoices into tax-compliant PDFs.
       Saves sole traders ~3h/month of invoicing; success = zero
       manual edits to the generated PDF. Zero-config by default;
       customization only via explicit template flag."
    - "Background-job scheduler for Go services. Goal: replace ops-
       managed cron with code-defined schedules that survive
       deploys; success = zero surprise job failures after a deploy.
       Constraint: job state lives in the app's own Postgres — no
       new infrastructure."

Deliverable 2 — DIFFERENTIATORS (up to 7, or empty):
  What makes this project different from the obvious alternatives.
  Competitive positioning, deliberate design choices that contradict
  what another project in the space would do. This class of signal
  prevents an agent from suggesting "why not just use X?" for an X
  you've already evaluated and rejected.

  Each bullet: "<alternative> → <what we do instead>" or "unlike
  <alternative>, we <choice> because <reason>".

  Bad examples:
    - "We're open source."           (not differentiation)
    - "Better than the rest."        (empty marketing)
    - Anything an agent can discover by reading competitor READMEs.

  Good examples:
    - "Unlike cron — schedules defined in code, survive deploys; no
       ops-managed crontab to drift from the repo."
    - "repomix / code2prompt: one-shot dump → we inject small briefs
       on cadence, no token flood."
    - "Cursor Rules: static prepend → we regenerate DYNAMIC sections
       per refresh from git + fs; recent work stays visible."

  If you genuinely don't see meaningful differentiation signals in
  the artefacts (ADRs comparing approaches, README "vs" sections,
  CLAUDE.md rejected-alternatives notes), leave this section with
  its placeholder — better empty than filler.

Deliverable 3 — INVARIANTS (as many as matter, typically 3-10):
  Project-size heuristic: a tiny CLI may have 0-3 real rules; a
  codebase with a formal architecture-rules ADR (e.g. an "ADR 0001"
  listing 6-9 mandatory rules) needs every one of those captured
  here — split across bullets, not merged. Missing a rule because
  you capped at 5 is a failure, not a virtue.
  Architectural or operational rules whose breakage causes non-obvious
  damage. Examples of the *class* of content to produce:
    - decisions captured in ADRs that contradict "obvious" approaches
    - hard constraints from past production incidents
    - "never do X because Y" where Y is invisible to a reader
    - "always X before Y" ordering requirements

  Bad examples (do NOT produce these — they're inferable):
    - "We use Rails 8."            (visible in Gemfile.lock)
    - "Code lives in app/."        (visible from ls)
    - "We have tests."             (visible from test/ or spec/)

  Good examples (produce things like these):
    - "All LLM calls must go through ruby_llm-contract — raw Faraday
       retries caused the Feb-15 outage (ADR-012)."
    - "Never run data migrations on Monday; the cron vacuum window
       overlaps and rollbacks stall."

Deliverable 4 — GOTCHAS (as many as matter, typically 3-7):
  Landmines whose fix is not obvious from code alone. Dependency quirks,
  rate limits, migrations needing manual steps, config that looks like a
  bug but is deliberate, platform-specific behaviour.

  Bad examples:
    - "Remember to run tests."     (trivial)
    - "Check for typos."           (not a project fact)

  Good examples:
    - "Reddit API caps at 60 req/min per OAuth app; scraper uses
       exponential backoff — do NOT add token rotation, it was tried
       and flagged as ToS abuse."
    - "Migration 20260219_* needs `rails data:migrate` after deploy;
       schema-only deploys leave an unusable null column."

Quality bar: 3 strong rules beat 10 weak ones. But capping at 5 when
a project has 9 canonical rules is equally wrong — dropping real
rules for the sake of tidiness means the agent will eventually break
one it never saw.

The hard ceiling is the Claude Code hook limit (10,000 chars).
context-revive's soft budget is 2,200. Briefs at 3,000-4,000 chars
are still well within the hook cap and fine for rich projects with
formal architecture rules. Don't self-censor for aesthetic reasons.

Required output format (exact indentation, no code fences, no
commentary). PURPOSE is a single line; DIFFERENTIATORS, INVARIANTS,
and GOTCHAS are bullet lists with two-space indent:

PURPOSE: <single 2-3 sentence summary, ≤ 400 chars>
DIFFERENTIATORS:
  - <alternative → our choice / rationale>
  - <...>
INVARIANTS:
  - <rule 1>
  - <rule 2>
  - <rule 3>
GOTCHAS:
  - <landmine 1>
  - <landmine 2>
  - <landmine 3>

Do two things, in order — do NOT stop after step 1:

  STEP 1 — For each placeholder section you chose to fill, print the
  generated block to the chat as a plain text preview so I can
  sanity-check it before it hits my repo. For sections you're
  PRESERVING, say so explicitly ("PURPOSE: keeping existing" /
  "INVARIANTS: keeping 5 existing rules verbatim"). If all three
  sections are already substantive, print a single line
  ("Nothing to fill — .revive/static.md already curated") and skip
  STEP 2 entirely.

  STEP 2 — Open .revive/static.md and edit it in place: replace
  ONLY the sections you identified as placeholders. Preserve file
  ordering (PURPOSE → DIFFERENTIATORS → INVARIANTS → GOTCHAS).
  Do NOT touch sections you decided to preserve. Use your editor
  tool (Edit / Write / str_replace — whatever your agent framework
  exposes); do NOT ask me to paste manually.

  After step 2, confirm with a one-line summary of which sections
  were rewritten and which were preserved, plus the final line
  count of .revive/static.md.

  After suggest finishes, run `revive audit | pbcopy` and paste
  that into a FRESH agent session — second-pass audit in a clean
  context window catches commonly-missed facts that this session
  is now too saturated to see.

If .revive/static.md does not exist, stop and tell me to run
`revive init` first — do NOT create it from scratch (PURPOSE
extraction is revive's job, not yours).
PROMPT_BODY
}

# Audit is a deliberately-separate LLM call from `suggest`. A fresh
# session avoids two failure modes of combined generation + audit:
#   1. Context-window saturation — by the time the agent finishes
#      generating + editing, attention is already spent. A second
#      pass in a clean window has more headroom for checklist work.
#   2. Self-critique sycophancy — LLMs asked to audit their own
#      recent output in the same turn tend to rubber-stamp it.
#      Fresh call, fresh eyes.
cmd_audit() {
  local sources=()
  [[ -f CLAUDE.md ]]    && sources+=("CLAUDE.md")
  [[ -f AGENTS.md ]]    && sources+=("AGENTS.md")
  [[ -f README.md ]]    && sources+=("README.md")
  [[ -d adr ]]          && sources+=("adr/*.md")
  [[ -d docs/adr ]]     && sources+=("docs/adr/*.md")
  [[ -d docs ]]         && sources+=("docs/*.md")
  [[ -f CHANGELOG.md ]] && sources+=("CHANGELOG.md")
  [[ -d .claude/skills ]] && sources+=(".claude/skills/*.md (if present)")
  [[ -d .cursor/rules ]]  && sources+=(".cursor/rules/*.md (if present)")

  cat >&2 <<'PROMPT_META'
# Paste this prompt into a FRESH Claude Code / Cursor / Aider session
# (not the one that just ran `revive suggest`). A clean context window
# is what gives this second pass its value — see commit log for why.
#
# Pipe to clipboard: `revive audit | pbcopy` (macOS).
# Requires: .revive/static.md already populated (via `revive suggest`
# or by hand). Without real content to audit against, this is a no-op.
PROMPT_META

  cat <<'PROMPT_HEADER'
Audit the STATIC sections of .revive/static.md against the artefacts
in this project. Find and propose bullets for NON-INFERABLE facts
that the current file misses. Do NOT rewrite what's already there —
only add what's missing.

Files to read (read `.revive/static.md` first — it's the thing being
audited):
  - .revive/static.md
PROMPT_HEADER

  local s
  if (( ${#sources[@]} > 0 )); then
    for s in "${sources[@]}"; do
      printf '  - %s\n' "$s"
    done
  fi

  cat <<'PROMPT_BODY'
  - git log --oneline -30 (signal for workflow rhythms / recent shifts)

Scope rules:

  - EDIT ONLY STATIC sections (PURPOSE, DIFFERENTIATORS, INVARIANTS,
    GOTCHAS). Never touch DYNAMIC (STATE, TODO, HOT_FILES, COMMANDS).
    DYNAMIC regenerates every refresh; any content captured there
    would immediately go stale.
  - MAY read DYNAMIC in the live brief as signal (e.g., HOT_FILES
    tells you where to look first; STATE tells you what's in flight).
  - Never REWRITE an existing PURPOSE, DIFFERENTIATORS, INVARIANTS,
    or GOTCHAS bullet. Only ADD net-new bullets.

Checklist — for each category, scan the artefacts and flag anything
that is both (a) non-inferable by reading the code and (b) not
already covered by an existing STATIC bullet:

  1. Toolchain specifics — exact invocations that differ from
     convention. Common misses: `.venv/bin/python -m pytest` rather
     than `pytest`; `bundle exec rspec` rather than `rspec`; custom
     bin/ launchers; non-default test/lint flags listed in
     CLAUDE.md §Stack or similar.
  2. Agent skill / knowledge-file discipline — if the project has
     `.claude/skills/*.md`, `.cursor/rules/*.md`, `docs/agents/*.md`,
     or any other "read this before writing X" convention, the
     "ALWAYS read before writing" rule is a mandatory INVARIANT.
  3. Workflow dichotomies — pairs of commands where picking the
     wrong one causes silent drift. Classic: `start` (incremental)
     vs `scan` (full rebuild); `dev migrate` vs `prod migrate`;
     `test` vs `test:integration`. Agent mis-picking = debug-hours.
  4. Privacy / OpSec — data that must NOT leak to public content
     (real paths, hours, customer/project names, credentials,
     gitignored artefacts cited in PRs).
  5. Cross-ADR process rules — panel-review requirements,
     pre-commit rituals, decision-journal hooks, supersession
     chains ("ADR X superseded by ADR Y"), cross-module contracts.
  6. Convention collisions — shared labels across files/sections
     that collide (e.g. "M1 in commits means PLAN.md §8, not §5"),
     or version-number conventions that don't match semver.

For each gap found, print ONE block in this exact shape:

  GAP: <one-line rationale, cite the artefact — "CLAUDE.md §Stack",
       "ADR 0001 rule 3", "commit abc123", etc.>
  SECTION: PURPOSE | DIFFERENTIATORS | INVARIANTS | GOTCHAS
  PROPOSED BULLET: - <the exact bullet to add, ≤ 120 chars>

If you find zero substantive gaps, say exactly "Audit: no gaps
found." and stop — do NOT pad with marginal findings to look busy.
A clean audit is a valid outcome.

Final step: after listing all gaps, ask me "Append these N bullets
to .revive/static.md? (y/n)" and wait for my answer. On yes, use
your editor tool to append each bullet to the end of its target
section, preserving existing content and section order. On no, do
nothing — I may have reasons to reject specific findings.

If .revive/static.md does not exist, stop and tell me to run
`revive init` + `revive suggest` first — audit has nothing to
audit against on a fresh project.
PROMPT_BODY
}

cmd_install_hook() {
  local scope="${1:-}" settings_path=".claude/settings.json"
  if [[ "$scope" == "--global" ]]; then
    settings_path="$HOME/.claude/settings.json"
  fi

  local revive_bin
  revive_bin=$(command -v revive 2>/dev/null || echo "$HOME/.local/bin/revive")
  local cmd_line="$revive_bin refresh"

  mkdir -p "$(dirname "$settings_path")"
  [[ -f "$settings_path" ]] || echo '{}' > "$settings_path"

  if ! command -v jq >/dev/null 2>&1; then
    cat >&2 <<EOF
jq not found. Merge this into $settings_path manually:

{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "$cmd_line" }
        ]
      }
    ]
  }
}
EOF
    exit 1
  fi

  if jq -e --arg cmd "$cmd_line" \
    '[.hooks.UserPromptSubmit[]?.hooks[]? | select(.command == $cmd)] | length > 0' \
    "$settings_path" >/dev/null 2>&1; then
    echo "hook already installed in $settings_path"
    return 0
  fi

  local tmp
  tmp=$(mktemp)
  jq --arg cmd "$cmd_line" '
    .hooks = (.hooks // {})
    | .hooks.UserPromptSubmit = (.hooks.UserPromptSubmit // [])
    | .hooks.UserPromptSubmit += [{"hooks":[{"type":"command","command":$cmd}]}]
  ' "$settings_path" > "$tmp"
  mv "$tmp" "$settings_path"
  echo "installed hook in $settings_path"
}

# --- main -------------------------------------------------------------------

main() {
  local cmd="${1:-}"
  [[ -z "$cmd" ]] && { usage; exit 1; }
  shift || true
  case "$cmd" in
    init)          cmd_init "$@" ;;
    show)          cmd_show "$@" ;;
    refresh)       cmd_refresh "$@" ;;
    suggest)       cmd_suggest "$@" ;;
    audit)         cmd_audit "$@" ;;
    install-hook)  cmd_install_hook "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       usage ;;
    *) echo "unknown command: $cmd" >&2; usage; exit 1 ;;
  esac
}

main "$@"
